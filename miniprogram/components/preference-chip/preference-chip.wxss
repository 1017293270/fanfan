.chip {
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: #5f514b;
  border: 2rpx solid #f1ded4;
  font-size: 26rpx;
}

.chip--selected {
  background: #f24b3a;
  color: #fff;
  border-color: #f24b3a;
}
