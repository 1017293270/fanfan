.card {
  padding: 38rpx;
  border-radius: 35rpx;
  background: #ffffff;
  border: 2rpx solid #f4e3d9;
}

.card__badge {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 19rpx;
  border-radius: 999rpx;
  background: #e9f5df;
  color: #3f7a2d;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.2;
}

.card__badge-icon {
  width: 31rpx;
  height: 31rpx;
  flex: none;
  border-radius: 50%;
}

.card__name {
  margin-top: 27rpx;
  font-size: 48rpx;
  font-weight: 900;
  color: #2f2926;
  line-height: 1.2;
}

.card__meta {
  margin-top: 13rpx;
  color: #7c6b62;
  font-size: 27rpx;
  line-height: 1.35;
}

.card__tags {
  margin-top: 25rpx;
  display: flex;
  gap: 13rpx;
  flex-wrap: wrap;
}

.card__tag {
  padding: 10rpx 15rpx;
  border-radius: 999rpx;
  background: #fff2e8;
  color: #9a4a22;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.2;
}

.card__reason {
  margin-top: 29rpx;
  color: #4c403b;
  font-size: 29rpx;
  line-height: 1.55;
}
