.page {
  padding: 78rpx 38rpx 58rpx;
}

.hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 38rpx;
}

.hero__avatar {
  width: 112rpx;
  height: 112rpx;
  flex: none;
}

.hero__brand {
  color: #f24b3a;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero__title {
  margin-top: 4rpx;
  color: #2f2926;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.15;
}

.hero__subtitle {
  margin-top: 8rpx;
  color: #8a7469;
  font-size: 25rpx;
  line-height: 1.3;
}

.preference-input {
  width: 100%;
  height: 169rpx;
  min-height: 169rpx;
  box-sizing: border-box;
  padding: 31rpx;
  border-radius: 31rpx;
  background: #ffffff;
  border: 2rpx solid #f4e3d9;
  color: #2f2926;
  font-size: 29rpx;
  line-height: 1.5;
}

.preference-input__placeholder {
  color: #8a7469;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 16rpx;
  margin-top: 23rpx;
}

.primary-button {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 38rpx 0 36rpx;
  height: 92rpx;
  line-height: normal;
  border-radius: 999rpx;
  background: #f24b3a;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
}

.primary-button--loading {
  opacity: 0.72;
}

.results {
  display: flex;
  flex-direction: column;
  gap: 27rpx;
}

.alternates {
  padding: 0 29rpx;
  border-radius: 31rpx;
  background: #fff;
  border: 2rpx solid #f4e3d9;
}

.section-title {
  padding: 25rpx 0 6rpx;
  color: #2f2926;
  font-size: 29rpx;
  font-weight: 900;
}

.action-bar {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr)) 1.25fr;
  gap: 13rpx;
}

.ghost-button,
.nav-button {
  width: 100%;
  box-sizing: border-box;
  height: 73rpx;
  line-height: normal;
  border-radius: 999rpx;
  padding: 0;
  font-size: 23rpx;
  font-weight: 800;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.action-button text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ghost-button {
  background: #ffffff;
  color: #5f514b;
  border: 2rpx solid #f4e3d9;
}

.nav-button {
  background: #477f32;
  color: #fff;
  font-weight: 800;
}
