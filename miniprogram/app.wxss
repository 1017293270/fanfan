page {
  min-height: 100%;
  background: #fff8ef;
  color: #2f2926;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
}

button {
  box-sizing: border-box;
  margin: 0;
  font: inherit;
}

button::after {
  border: 0;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
