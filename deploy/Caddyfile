{$APP_DOMAIN:localhost} {
  root * /srv
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8787
  }

  handle /health {
    reverse_proxy api:8787
  }

  handle {
    try_files {path} /index.html
    file_server
  }

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }
}
